{
  "compilerOptions": {
    "declaration": true,
    "module": "ESNext",
    "target": "ES2015",
    "lib": ["es2015", "dom"],
    "outDir": "dist/esm",
    "rootDir": "src",
    "moduleResolution": "node",
    "skipLibCheck": true,
    "sourceMap": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
